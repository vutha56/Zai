# ============================================================
# XAUUSD CRT-4H Trading Signals — environment configuration
# Copy this file to backend/.env and fill in your keys.
# ============================================================

# --- Data provider (REQUIRED for live candles) ---
# Free key: https://twelvedata.com/pricing  (free tier ~8 req/min, 800/day)
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
SYMBOL=XAU/USD
TIMEFRAME=4h

# --- ZAI (GLM) LLM for textual analysis (REQUIRED for AI analysis) ---
# Key + docs: https://z.ai/model-api
# OpenAI-compatible endpoint. Models: glm-5.2, glm-4.6, etc.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-5.2

# --- Telegram alerts (OPTIONAL) ---
# Create a bot via @BotFather -> get token. Chat id: message @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Strategy tuning (OPTIONAL, defaults shown) ---
# CRT_RANGE_WINDOW=6
# CRT_DISPLACEMENT_K=1.0
# CRT_ATR_PERIOD=14
# CRT_SL_BUFFER_ATR=0.15
# CRT_MIN_RR=2.0
# CRT_LOOKFORWARD_CANDLES=3
# CRT_SCAN_LOOKBACK=30
# SCAN_CRON_MINUTES=*/15
